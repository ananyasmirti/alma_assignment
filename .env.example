# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://alma:alma@localhost:5432/alma

# ── Auth ────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_HOURS=8

# ── Email (Resend) ───────────────────────────────────────────────────────────
# Get your key at https://resend.com
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@yourdomain.com
# The attorney inbox that receives new lead notifications
ATTORNEY_EMAIL=attorney@yourdomain.com

# ── File Storage ─────────────────────────────────────────────────────────────
STORAGE_BACKEND=local
UPLOADS_DIR=./uploads

# S3 (only required when STORAGE_BACKEND=s3)
# AWS_BUCKET=alma-resumes
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=["http://localhost:3000"]
